{
  "manifest_version": 3,
  "name": "bookmarkit: Bookmark Manager Extension",
  "version": "1.0.0",
  "description": "Organize, tag, search, and rate bookmarks quickly — import/export and optional AI-assisted features for smarter management.",
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "bookmarks"],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
